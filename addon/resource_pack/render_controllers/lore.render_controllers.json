{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.lore_default": {
      "geometry": "Geometry.default",
      "materials": [
        { "*": "Material.default" }
      ],
      "textures": ["Texture.default"]
    },
    "controller.render.lore_variant": {
      "arrays": {
        "textures": {
          "Array.skins": ["Texture.default", "Texture.vanguard"]
        }
      },
      "geometry": "Geometry.default",
      "materials": [
        { "*": "Material.default" }
      ],
      "textures": ["Array.skins[query.variant]"]
    }
  }
}
